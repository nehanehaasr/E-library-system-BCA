<!doctype html>
<html class="no-js" lang="en">

<head>
    <%- include('../partials/student/headerFiles', { title: 'AKKHOR | Available Books' }) %>

        <style>
            .table td,
            .table th {
                vertical-align: middle;
            }

            
            /* Extra small devices (phones, 600px and down) */
            @media only screen and (max-width: 600px) {
                .dynamic-height {
                    height: 100vh;
                }
            }

            /* Small devices (portrait tablets and large phones, 600px and up) */
            @media only screen and (min-width: 600px) {
                .dynamic-height {
                    height: 100vh;
                }
            }
        </style>
</head>

<body onload="fetchcategories()">

    <!-- Preloader Start Here -->
    <div id="preloader"></div>
    <!-- Preloader End Here -->

    <div id="wrapper" class="wrapper bg-ash">

        <%- include('../partials/student/topHeader') %>


            <div class="dashboard-page-one">

                <%- include('../partials/student/sideBar') %>

                    
                        <!-- Breadcubs Area Start Here -->
                        <!-- <div class="breadcrumbs-area"></div> -->
                        <!-- Breadcubs Area End Here -->

                        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 dashboard-content-one dynamic-height">
                             
                            <div id="books"></div>

                            <%- include('../partials/admin/footer') %>
                        </div>
                        
            </div>
            
            <!-- Page Area End Here -->
    </div>

    <%- include('../partials/student/footerScripts') %>




<script>
    fetch('/user/purchased-data')
.then(res => res.json())
.then(data => {

    let html = '';

    data.records.forEach(item => {

        let b = item.book;

        html += `
        <div style="border:1px solid #ccc; padding:10px; margin:10px; w:60px">
            <div class="card-body text-center">

                <img src="${b.photo}"
                     style="width:80px;height:100px;object-fit:cover;">

                <h5 class="card-title">${b.title}</h5>
                <p class="text-muted">${b.author || "Unknown Author"}</p>

                <a href="/user/read/${b.id}" class="btn btn-success btn-sm">
                    📖 Read
                </a>

            </div>
        </div>
        `;
    });

    document.getElementById('books').innerHTML = html;
});
</script>
</body>

</html>