<script>
    async function ReadissuedData()
    {
        try{

            var res =await fetch('/user/userbookdata');
            res = await res.json();
            var records = res.records;
            console.log(records);

            var html=``;
            for(var x of records)
            {
                let timestamp=x.issuedate;
                let timestamp2=x.returndate;

                let dateObj = new Date(timestamp);
                let dateObj2 = new Date(timestamp2);

                let issue = dateObj.toISOString().split("T")[0];
                let ret = dateObj2.toISOString().split("T")[0];


                if(x.status=='Returned') {
                    html += `<tr>`
                    html += `<td>${x.id}</td>`
                    html += `<td>${x.user.name}</td>`
                    html += `<td>${x.book.title}</td>`
                    html += `<td>${issue}</td>`
                    html += `<td>${ret}</td>`
                    html += `<td><p style="color: green">${x.status}</p></td>`
                    html += `</tr>`
                }else
                {
                    html += `<tr>`
                    html += `<td>${x.id}</td>`
                    html += `<td>${x.user.name}</td>`
                    html += `<td>${x.book.title}</td>`
                    html += `<td>${issue}</td>`
                    html += `<td>${ret}</td>`
                    html += `<td><p style="color: red">${x.status}</p></td>`
                    html += `</tr>`
                }
            }

            document.getElementById('records').innerHTML=html;
        }catch(e)
        {
            console.log(e.message);
        }
    }

</script>





