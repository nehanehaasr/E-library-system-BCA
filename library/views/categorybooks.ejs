
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Search Results</title>
    <script src="https://cdn.tailwindcss.com"></script>


<style>
    body {
        background: #f5f7fb;
    }

    .page-title {
        text-align: center;
        font-weight: bold;
        margin: 20px 0;
        color: #333;
    }

    .book-card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
        transition: 0.3s;
        background: #fff;
        height: 100%;
    }

    .book-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }

    .book-img {
        height: 220px;
        object-fit: cover;
    }

    .badge-free {
        background: #28a745;
        color: #fff;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
    }

    .badge-paid {
        background: #dc3545;
        color: #fff;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
    }

    .btn-buy {
        background: linear-gradient(45deg, #ff9800, #ff5722);
        color: white;
        border: none;
        border-radius: 8px;
        width: 100%;
        padding: 8px;
        font-weight: bold;
    }

    .btn-download {
        background: linear-gradient(45deg, #4caf50, #2e7d32);
        color: white;
        border: none;
        border-radius: 8px;
        width: 100%;
        padding: 8px;
        font-weight: bold;
    }

    
</style>
</head>

<body class="bg-gray-100">
    <div class="row g-4">

        <div class="bg-orange-600 p-4 text-white text-center text-xl font-bold">
        📚 Category Books
    </div>
    <div class="container mt-4 " id="div-con">
<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 px-10 mt-8 ">

        <% if (books.length> 0) { %>

            <% books.forEach(book=> { %>

                <div class="bg-white p-4 rounded-xl shadow-lg 
        hover:shadow-2xl hover:-translate-y-2 transition duration-300">

                    <img src="<%= book.photo %>" class="w-full h-50 object-cover rounded">

                    <h3 class="mt-2 font-bold text-lg">
                        <%= book.title %>
                    </h3>

                    <p class="text-sm text-gray-600">
                        <%= book.author %>
                    </p>

                    <!-- Price -->
                    <p class="text-green-600 font-semibold">
                        <!-- Price -->
                        <% if (Number(book.price)===0) { %>
                            <span class="text-green-600 font-bold">Free</span>
                            <% } else { %>
                                <span class="text-red-500 font-bold">Paid</span>
                                <% } %>
                    </p>

                    <!-- Button -->
                    <% if (parseFloat(book.price)===0) { %>

                        <!-- FREE BOOK -->
                        <a href="/download/<%= book.id %>"
                            class="block mt-3 bg-green-500 text-white text-center py-2 rounded hover:bg-green-600">
                            Download
                        </a>

                        <% } else { %>

                            <!-- PAID BOOK -->
                            <a href="/buy/<%= book.id %>"
                                class="block mt-3 bg-orange-500 text-white text-center py-2 rounded hover:bg-red-600">
                                Buy Now
                            </a>

                            <% } %>
                </div>

                <% }) %>

                    <% } else { %>

                        <!-- No Result -->
                        <div class="col-span-4 text-center mt-10">
                            <p class="text-red-500 text-lg">
                                ❌ No books found in this category
                            </p>
                        </div>

                        <% } %>

    </div>



</div>

<footer class="bg-orange-600 text-white mt-10">

    <div class="max-w-6xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- About -->
        <div>
            <h2 class="text-xl font-bold mb-3">📚 E-Library System</h2>
            <p class="text-orange-100 text-sm leading-6">
                Read books online anytime, anywhere. Explore free and paid books and grow your knowledge.
            </p>
        </div>

        <!-- Links -->
        <div>
            <h3 class="text-lg font-semibold mb-3">Quick Links</h3>
            <ul class="space-y-2 text-orange-100 text-sm">
                <li><a href="/" class="hover:text-white">Home</a></li>
                <li><a href="/books" class="hover:text-white">Books</a></li>
                <li><a href="/select-role" class="hover:text-white">Library</a></li>
                <li><a href="/search" class="hover:text-white">Search</a></li>
            </ul>
        </div>

        <!-- Social -->
        <div>
            <h3 class="text-lg font-semibold mb-3">Follow Us</h3>

            <div class="flex space-x-5 text-xl">

                <a href="https://www.facebook.com/" class="hover:scale-110 transition">
                    <i class="bi bi-facebook"></i>
                </a>

                <a href="https://www.instagram.com/" class="hover:scale-110 transition">
                    <i class="bi bi-instagram"></i>
                </a>

                <a href="https://www.youtube.com/" class="hover:scale-110 transition">
                    <i class="bi bi-youtube"></i>
                </a>

                <a href="https://www.google.com/" class="hover:scale-110 transition">
                    <i class="bi bi-google"></i>
                </a>

            </div>

        </div>

    </div>

    <!-- Bottom -->
    <div class="border-t border-orange-400 text-center py-4 text-orange-100 text-sm">
        © 2026 <span class="font-semibold text-white">E-Library System</span> | All Rights Reserved
    </div>

</footer>
</body>