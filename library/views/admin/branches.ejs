<!doctype html>
<html class="no-js" lang="">

<head>
    <%- include('../partials/admin/headerFiles', {title: 'AKKHOR | Home 1'}) %>

    <style>
        .form-select {
            display: block;
            width: 100%;
            padding: 0.375rem 2.25rem 0.375rem 0.75rem;
            font-size: 2rem;
            font-weight: 400;
            line-height: 1.5;
            color: #212529;
            background-color: rgba(244, 243, 244, 0.93);
            background-clip: padding-box;
            border: 2px solid #ced4da;
            border-radius: 0.4rem;
        }

        .error{
            color: red;
            font-size: 15px;
        }


    </style>
</head>

<body onload="fetchcourse()">

<!-- Preloader Start Here -->
<div id="preloader"></div>
<!-- Preloader End Here -->

<div id="wrapper" class="wrapper bg-ash">
    <!-- Header Menu Area Start Here -->
    <%- include('../partials/admin/topbar') %>
    <!-- Header Menu Area End Here -->

    <!-- Page Area Start Here -->
    <div class="dashboard-page-one">
        <%- include('../partials/adminsidebar') %>

        <div class="dashboard-content-one">
            <!-- Breadcubs Area Start Here -->
            <div class="breadcrumbs-area">
            </div>
            <!-- Breadcubs Area End Here -->

            <!-- Add New Book Area ends Here -->
            <div class="card height-auto">
                <div class="card-body">
                    <div class="heading-layout1">
                        <div class="item-title">
                            <h3>Add New Branch</h3>
                        </div>
                    </div>

                    <form class="new-added-form" id="registrationForm">
                        <div class="row">
                            <div class="col-xl-3 col-lg-6 col-12 form-group">
                                <div class="mb-3">
                                    <label for="name">Select Course</label>
                                    <select id="categories" class="form-select" name="name" required></select>
                                </div>
                                
                                <div>
                                    <label>Branch Name / Department Name</label>
                                    <input type="text" placeholder="" id="name" name="dept" class="form-control" required>
                                </div>
                            </div>

                            <div class="col-12 form-group mg-t-8">
                                <button type="button" onclick="add()" class="btn-fill-lg btn-gradient-yellow btn-hover-bluedark">
                                    Save
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="card height-auto">
                <div class="card-body">
                    <div class="heading-layout1">
                        <div class="item-title">
                            <h3>List of Branch</h3>
                        </div>
                    </div>

                    <table class="table table-bordered table-striped  table-light table-hover mt-3">
                        <thead>
                        <tr>
                            <!-- <th>Id</th> -->
                            <th>Course Name</th>
                            <th>Branch Name</th>
                        </tr>
                        </thead>
                        <tbody id="records"></tbody>
                    </table>
                </div>
            </div>

            <!-- Add New Book Area End Here -->
            <%- include('../partials/admin/footer.ejs') %>
        </div>
    </div>
    <!-- Page Area End Here -->
</div>

<%- include('../partials/admin/footerScripts.ejs') %>

<script>
    async function fetchcourse(){

        var res = await fetch('/admin/fetchcourse');
        res = await res.json();
        var records = res.records;
        // console.log(records);
        var html =`<option value="">Select course</option>`
        for( var x of records)
        {
            html+=`<option value="${x.id}">${x.name}</option>`
        }
        document.getElementById("categories").innerHTML=html;
        viewbranch()
    }

    async function add()
    {
        if ($("#registrationForm").valid())
        {
            var name = document.getElementById("name").value;
            var courseId = document.getElementById("categories").value;

            var formData = new FormData();
            formData.append('name',name)
            formData.append('courseId',courseId)
            var res =await fetch("/admin/addbranch",{
                method:"POST",
                body:formData
            });
            res = await res.json();
            // console.log(res);
            if(res.error){
                Qual.errordb("Error", res.message);
            }else
            {
                viewbranch()
                Qual.successdb("Added Successfully", res.message);
                document.getElementById("registrationForm").reset();
            }
        }
    }
    
    async function viewbranch()
    {
        try{

            var res =await fetch('/admin/viewbranch');
            res = await res.json();
            var records = res.records;
            var html=``;
            //console.log(records);
            for(var x of records)
            {
                html+=`<tr>`
                //html+=`<td>${x.id}</td>`
                html+=`<td>${x.course.name}</td>`
                html+=`<td>${x.name}</td>`
                html+=`<td><button type="button" class ="btn btn-danger btn-sm" onclick="Deletedata(${x.id})">Delete</button></td>`
                html+=`</tr>`
            }
            document.getElementById('records').innerHTML=html;
        }catch(e)
        {
            console.log(e.message);
        }
    }

    async function Deletedata(id)
    {
        if(confirm("Are you sure to delete?")) {
            var res = await fetch('/admin/delete/'+id ,{ method :'DELETE'});
            res = await res.json();
            viewbranch();
        }
    }

</script>


</body>

</html>