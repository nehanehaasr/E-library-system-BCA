<script src="https://cdn.jsdelivr.net/gh/cosmogicofficial/quantumalert@latest/minfile/quantumalert.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    async function fetchdegree(){
        var res = await fetch('/admin/fetchdegree');
        res = await res.json();
        var records = res.records;
        // console.log(records);
        var html =`<option value="">Select category</option>`
        for( var x of records)
        {
            html+=`<option value="${x.id}">${x.name}</option>`
        }
        document.getElementById("categories").innerHTML=html;
        viewsubcategory()
    }

    async function add()
    {
        if($("#registrationForm").valid())
        {
            const name = document.getElementById("name").value;
            const degreeId = document.getElementById("categories").value;

            const formData = new FormData();
            formData.append('name', name);
            formData.append('degreeId', degreeId);

            let res = await fetch("/admin/addcourse",{
                method:"POST",
                body:formData
            });

            res = await res.json();

            if(res.error){
                Qual.errordb("Error", res.message);
            } else {
                viewsubcategory();
                Qual.successdb("Added Successfully", res?.message);
                document.getElementById("registrationForm").reset();
            }
        }
    }
    
    async function viewsubcategory()
    {
        try{

            var res =await fetch('/admin/viewcourse');
            res = await res.json();
            var records = res.records;
            var html=``;
            //console.log(records);
            for(var x of records)
            {
                html+=`<tr>`
                //html+=`<td>${x.id}</td>`
                html+=`<td>${x.degree.name}</td>`
                html+=`<td>${x.name}</td>`
                html+=`<td><button type="button" class ="btn btn-danger btn-sm" onclick="Deletedata(${x.id})">Delete</button></td>`
                html+=`</tr>`
            }
            document.getElementById('records').innerHTML=html;
        }catch(e)
        {
            console.log(e.message);
        }
    }

    async function Deletedata(id)
    {
        if(confirm('Are you sure to delete this?')) {
            var res = await fetch('/admin/deletecourse/'+id ,{ method :'DELETE'});
            res = await res.json();
            viewsubcategory();
        }
    }

</script>


</body>

</html>