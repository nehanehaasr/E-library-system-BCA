<body onload="fetchdegree()">

<!-- Preloader Start Here -->
<div id="preloader"></div>
<!-- Preloader End Here -->

<div id="wrapper" class="wrapper bg-ash">
    <!-- Header Menu Area Start Here -->
    <%- include('../partials/admin/topbar') %>
    <!-- Header Menu Area End Here -->

    <!-- Page Area Start Here -->
    <div class="dashboard-page-one">
        <%- include('../partials/adminsidebar') %>

        <div class="dashboard-content-one">
            <!-- Breadcubs Area Start Here -->
            <div class="breadcrumbs-area">
            </div>
            <!-- Breadcubs Area End Here -->

            <!-- Add New Book Area Start Here -->
            <div class="card height-auto">
                <div class="card-body">
                    <div class="heading-layout1">
                        <div class="item-title">
                            <h3>Add Course</h3>
                        </div>
                    </div>

                    <form class="new-added-form" id="registrationForm">
                        <div class="row">
                            <div class="col-xl-3 col-lg-6 col-12 form-group">
                                <div >
                                    <label for="name">Select Branch</label>
                                    <select id="categories" class="form-select" required>

                                    </select>
                                </div>
                                <label>Course Name</label>
                                <input type="text" placeholder="" id="name" class="form-control" name="name" required>
                            </div>

                            <div class="col-12 form-group mg-t-8">
                                <button type="button" onclick="add()" class="btn-fill-lg btn-gradient-yellow btn-hover-bluedark">Save</button>

                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <!-- Add New Book Area End Here -->

            <div class="card height-auto">
                <div class="card-body">
                    <div class="heading-layout1">
                        <div class="item-title">
                            <h3>List of Courses</h3>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped  table-light table-hover mt-3">
                            <thead>
                            <tr>
                                <!-- <th>Id</th> -->
                                <th>Degree Name</th>
                                <th>Course Name</th>
                                <th></th>
                            </tr>
                            </thead>
                            <tbody id="records"></tbody>
                        </table>
                    </div>
                </div>
            </div>

           <%- include('../partials/admin/footer.ejs') %>
        </div>
    </div>
    <!-- Page Area End Here -->
</div>


<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
