<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Change Password</title>

     <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #fff7ed, #ffedd5);
        }

        .container {
            background: linear-gradient(135deg, #ffffff, #fff7ed);
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
            width: 320px;
            text-align: center;
        }

        h2 {
            color: #ea580c;
            /* orange theme */
            margin-bottom: 20px;
            font-weight: 600;
        }

        .input-field {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 14px;
        }

        .input-field:focus {
            outline: none;
            border-color: #f97316;
            box-shadow: 0 0 0 2px rgba(249, 115, 22, 0.2);
        }

        .btn {
            background-color: #f97316;
            color: white;
            border: none;
            padding: 10px;
            width: 100%;
            cursor: pointer;
            border-radius: 999px;
            font-size: 16px;
            font-weight: 600;
            margin-top: 10px;
            transition: background-color 0.3s ease;
        }

        .btn:hover {
            background-color: #ea580c;
        }

        .error {
            color: #dc2626;
            font-size: 12px;
            text-align: left;
            display: block;
            margin-top: -6px;
            margin-bottom: 8px;
        }

        .text-center {
            margin-top: 15px;
        }

        .text-center a {
            color: #374151;
            text-decoration: none;
            font-size: 14px;
        }

        .text-center a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

<div class="container" id="registrationForm">
    <h2>Change Password</h2>

    <input type="email" id="email" class="input-field" name="email" placeholder="Enter Registered Email">
    <span class="error" id="email-error"></span>

    <input type="password" id="current-password" class="input-field" name="current" placeholder="Current Password">
    <span class="error" id="current-password-error"></span>

    <input type="password" id="new-password" class="input-field" name="new" placeholder="New Password">
    <span class="error" id="new-password-error"></span>

    <button type="button" class="btn" onclick="changePassword()">Update Password</button>

    <div class="text-center"><a href="/user/dashboard" class="text-dark">Home</a></div>
</div>

<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/gh/cosmogicofficial/quantumalert@latest/minfile/quantumalert.js"></script>

<script>
    $(document).ready(function () {

        // Validate Email Field
        $("#email").on("blur", function () {
            var email = $(this).val();
            var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (email.trim() === "") {
                $("#email-error").text("Email is required");
                $(this);
            } else if (!emailPattern.test(email)) {
                $("#email-error").text("Enter a valid email");
                $(this);
            } else {
                $("#email-error").text("");
                $(this);
            }
        });

        // Validate Current Password Field
        $("#current-password").on("blur", function () {
            var password = $(this).val();
            if (password.trim() === "") {
                $("#current-password-error").text("Current password is required");
                $(this);
            } else {
                $("#current-password-error").text("");
                $(this);
            }
        });

        // Validate New Password Field
        $("#new-password").on("blur", function () {
            var newPassword = $(this).val();
            if (newPassword.trim() === "") {
                $("#new-password-error").text("New password is required");
                $(this);
            }
            // else if (newPassword.length < 6) {
            //     $("#new-password-error").text("Password must be at least 6 characters");
            //     $(this).css("border", "2px solid red");
            // }
            else {
                $("#new-password-error").text("");
                $(this);
            }
        });

    });

    // Change Password Function
    async function changePassword() {
        var email = $("#email").val();
        var password = $("#current-password").val();
        var newpassword = $("#new-password").val();

        // Trigger Blur Events to Validate Inputs
        $("#email, #current-password, #new-password").blur();

        // If any error messages exist, stop submission
        if ($("#email-error").text() || $("#current-password-error").text() || $("#new-password-error").text()) {
            return;
        }

        var res = await fetch('/user/updatepassword', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                email: email,
                password: password,
                newpassword: newpassword
            })
        });

        res = await res.json();
        console.log(res);

        if(res.error){
            Qual.errordb("Error", res.message);
        }else
        {
            Qual.successdb("Success", res.message);
            //1000=1sec, 2000=2sec

        }
    }
</script>

</body>
</html>
